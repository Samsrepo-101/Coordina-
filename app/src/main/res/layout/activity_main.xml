<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="COORDINA"
            android:textColor="@color/grey_text"
            android:textSize="14sp"
            android:letterSpacing="0.1"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Emergency Response"
            android:textColor="@color/black"
            android:textSize="28sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Ripple/Glow Layers -->
    <View
        android:id="@+id/pulse_view_1"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_ripple_glow"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="@id/sos_button"
        app:layout_constraintEnd_toEndOf="@id/sos_button"
        app:layout_constraintStart_toStartOf="@id/sos_button"
        app:layout_constraintTop_toTopOf="@id/sos_button" />

    <View
        android:id="@+id/pulse_view_2"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_ripple_glow"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="@id/sos_button"
        app:layout_constraintEnd_toEndOf="@id/sos_button"
        app:layout_constraintStart_toStartOf="@id/sos_button"
        app:layout_constraintTop_toTopOf="@id/sos_button" />

    <View
        android:id="@+id/pulse_view_3"
        android:layout_width="180dp"
        android:layout_height="180dp"
        android:background="@drawable/bg_ripple_glow"
        android:alpha="0"
        app:layout_constraintBottom_toBottomOf="@id/sos_button"
        app:layout_constraintEnd_toEndOf="@id/sos_button"
        app:layout_constraintStart_toStartOf="@id/sos_button"
        app:layout_constraintTop_toTopOf="@id/sos_button" />

    <!-- SOS Button -->
    <FrameLayout
        android:id="@+id/sos_button"
        android:layout_width="235dp"
        android:layout_height="226dp"
        android:background="@drawable/bg_circle_red"
        android:elevation="16dp"
        android:outlineAmbientShadowColor="@color/red_main"
        android:outlineSpotShadowColor="@color/red_main"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.45">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_sos" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="sos"
                android:textAllCaps="true"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold" />
        </LinearLayout>
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="48dp"
        android:text="Tap to report an emergency"
        android:textColor="@color/grey_text"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/sos_button" />

    <!-- Bottom Navigation Mockup -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/white"
        android:orientation="horizontal"
        android:elevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <View
                android:layout_width="60dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_report_card"
                android:backgroundTint="@color/light_red"
                android:alpha="0.8" />
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginTop="-28dp"
                android:src="@drawable/ic_home"
                app:tint="@color/red_main" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Home"
                android:textColor="@color/red_main"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_report"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_emergency_header"
                app:tint="@color/grey_text" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Report"
                android:textColor="@color/grey_text"
                android:textSize="12sp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_account"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_account"
                app:tint="@color/grey_text" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Account"
                android:textColor="@color/grey_text"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>