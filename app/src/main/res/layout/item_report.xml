<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    android:background="@drawable/bg_report_card"
    android:backgroundTint="@color/white"
    android:orientation="horizontal"
    android:padding="16dp">

    <FrameLayout
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:background="@drawable/bg_report_card"
        android:backgroundTint="#FFF1F1">

        <ImageView
            android:id="@+id/iv_report_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_emergency_header"
            app:tint="@color/red_main" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_report_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medical Emergency"
            android:textColor="@color/black"
            android:textSize="18sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_location"
                app:tint="@color/grey_text" />

            <TextView
                android:id="@+id/tv_report_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Location"
                android:textColor="@color/grey_text"
                android:textSize="14sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_home"
                app:tint="@color/grey_text" />

            <TextView
                android:id="@+id/tv_report_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:text="Time"
                android:textColor="@color/grey_text"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_report_merged"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="+2 merged"
                android:textColor="#A084E8"
                android:textSize="14sp"
                android:visibility="gone" />
        </LinearLayout>

        <!-- Status Timeline Labels -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tv_label_reported"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Reported"
                android:textColor="@color/red_main"
                android:textSize="10sp"
                android:gravity="start" />
            <TextView
                android:id="@+id/tv_label_en_route"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="En Route"
                android:textColor="#E0E0E0"
                android:textSize="10sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/tv_label_on_site"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="On Site"
                android:textColor="#E0E0E0"
                android:textSize="10sp"
                android:gravity="center" />
            <TextView
                android:id="@+id/tv_label_resolved"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Resolved"
                android:textColor="#E0E0E0"
                android:textSize="10sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Status Timeline dots and lines -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp">

            <ImageView
                android:id="@+id/iv_step_reported"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/bg_circle_red"
                app:tint="@color/red_main" />

            <View
                android:id="@+id/v_line_1"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />

            <ImageView
                android:id="@+id/iv_step_en_route"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/bg_circle_red"
                app:tint="#E0E0E0" />

            <View
                android:id="@+id/v_line_2"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />

            <ImageView
                android:id="@+id/iv_step_on_site"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/bg_circle_red"
                app:tint="#E0E0E0" />

            <View
                android:id="@+id/v_line_3"
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:background="#E0E0E0" />

            <ImageView
                android:id="@+id/iv_step_resolved"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:src="@drawable/bg_circle_red"
                app:tint="#E0E0E0" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
